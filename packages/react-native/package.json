{
  "name": "@crockalet/react-native-app-intents",
  "version": "0.1.4",
  "description": "React Native runtime, authoring API, codegen, CLI, and Expo plugin for App Intents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crockalet/react-native-app-intents.git",
    "directory": "packages/react-native"
  },
  "bin": {
    "app-intents": "dist/cli/cli.js"
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "ios",
    "android/build.gradle",
    "android/src",
    "ReactNativeAppIntents.podspec",
    "app.plugin.js",
    "README.md",
    "docs"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "react-native": "./dist/index.js",
  "exports": {
    ".": {
      "react-native": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./codegen": {
      "types": "./dist/codegen/index.d.ts",
      "default": "./dist/codegen/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "default": "./dist/cli/index.js"
    },
    "./expo-plugin": {
      "types": "./dist/expo-plugin/index.d.ts",
      "default": "./dist/expo-plugin/index.js"
    },
    "./app.plugin.js": {
      "default": "./app.plugin.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test"
  },
  "dependencies": {
    "@expo/config": "^55.0.16",
    "@expo/config-plugins": "^55.0.8",
    "@expo/require-utils": "^55.0.5"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  }
}
