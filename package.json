{
  "name": "react-native-app-intents",
  "private": true,
  "workspaces": [
    "packages/*",
    "example",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "clean": "rm -rf example/dist packages/*/dist",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "test": "for dir in packages/*; do (cd \"$dir\" && bun test) || exit 1; done",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "typescript": "6.0.3"
  },
  "packageManager": "bun@1.3.6"
}
