{
  "name": "@react-native-app-intents/example",
  "version": "0.0.0",
  "private": true,
  "description": "Example workspace package used to exercise the scaffolded APIs.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "react-native": "./dist/src/index.js",
  "exports": {
    ".": {
      "react-native": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./config": {
      "types": "./dist/src/config.d.ts",
      "default": "./dist/src/config.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test"
  },
  "dependencies": {
    "@react-native-app-intents/codegen": "workspace:*",
    "@react-native-app-intents/core": "workspace:*",
    "@react-native-app-intents/expo-plugin": "workspace:*",
    "@react-native-app-intents/react-native": "workspace:*"
  }
}
